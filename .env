# API Keys (Free signup at https://www.alphavantage.co/support/#api-key)
ALPHA_VANTAGE_KEY=9GXALPGK3V7MGHYB  # Temporary - real key se replace karein later

# Database (SQLite for now)
DB_URL=sqlite:///stock_data.db

# Application Settings
LOG_LEVEL=INFO
MAX_RETRIES=3
REQUEST_TIMEOUT=30
MAX_CONCURRENT_REQUESTS=10

# Stock Symbols to Track
DEFAULT_SYMBOLS=["AAPL", "GOOGL", "MSFT", "AMZN", "TSLA", "META", "NVDA"]

# Data Quality Thresholds
MIN_VOLUME_THRESHOLD=1000
MAX_VOLATILITY_THRESHOLD=0.5
MIN_DATA_POINTS=5

# Anomaly Detection
ENABLE_ANOMALY_DETECTION=true
ENABLE_ALERTS=false  # Initially false, later enable
ISOLATION_FOREST_CONTAMINATION=0.1

# Dashboard
ENABLE_DASHBOARD=true